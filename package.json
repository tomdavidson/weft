{
  "name": "@zflow/zbuild",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "zbuild": "./src/cli/index.ts"
  },
  "scripts": {
    "check": "tsc --noEmit",
    "build": "bun build src/cli/index.ts --compile --outfile zbuild",
    "lint": "oxlint;  eslint",
    "lint:ox": "oxlint",
    "lint:fp": "eslint -c eslint.config.mjs",
    "lint:fix": "oxlint --fix; eslint --fix",
    "fmt": "dprint fmt",
    "fmt:check": "dprint check",
    "refac": "bash refac.sh",
    "ci": "date --rfc-3339=second; echo \"*** RUNNING LINTERS: ***\" && bun run lint; echo \"*** RUNNING TESTS: ***\" && bun test"
  },
  "dependencies": {
    "mustache": "^4.2.0",
    "neverthrow": "^8.0.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/mustache": "^4.2.0",
    "eslint": "^9.0.0",
    "eslint-plugin-boundaries": "^5.0.0",
    "eslint-plugin-functional": "^9.0.0",
    "eslint-plugin-oxlint": "^1.51.0",
    "eslint-plugin-prefer-arrow-functions": "^3.6.0",
    "fast-check": "^3.0.0",
    "oxlint": "^1.0.0",
    "oxlint-tsgolint": "^0.16.0",
    "typescript": "^5.5.0"
  }
}
